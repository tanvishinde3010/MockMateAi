# Groq LLM API (OpenAI-compatible) — used by /api/evaluate and /api/followup
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: override the model id (default: openai/gpt-oss-20b)
# List live ids: GET https://api.groq.com/openai/v1/models
GROQ_MODEL=openai/gpt-oss-20b

# Optional: server port (default 5000)
PORT=5000
