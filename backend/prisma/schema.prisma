datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String   @id @default("user-1")
  name            String
  email           String   @unique
  avatar          String
  targetRole      String
  experienceLevel String
  skills          String   // Comma-separated list of skills
  summary         String
  resumeName      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model InterviewSession {
  id          String           @id
  role        String
  category    String
  difficulty  String
  date        String
  duration    String
  score       Int
  skills      String           // JSON stringified skills breakdown
  mode        String           @default("full")   // "full" | "quick"
  level       String           @default("easy")   // "easy" | "medium" | "advanced"
  roundScores String?          // JSON stringified per-round scores { mcq, interview, coding }
  answers     QuestionAnswer[]
  createdAt   DateTime         @default(now())
}

model QuestionAnswer {
  id           String           @id @default(uuid())
  question     String
  userAnswer   String
  score        Int
  strengths    String           // JSON stringified array of strengths
  improvements String           // JSON stringified array of improvements
  modelAnswer  String
  complexity   String?          // JSON stringified Big-O complexity {time, space}
  roundType    String?          // "mcq" | "interview" | "coding"
  sessionId    String
  session      InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id        String   @id
  subject   String
  category  String
  priority  String
  desc      String
  status    String   @default("Open")
  date      String
  createdAt DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  text      String
  time      String
  unread    Boolean  @default(true)
  type      String   // insight, reminder, achievement, system, security
  createdAt DateTime @default(now())
}
